// ADMIN EVENTS
function AdminEventsScreen({ onBack, onShowToast }: { onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const [events, setEvents] = useState(StorageDB.events.get())
  const [showModal, setShowModal] = useState(false)
  const [editingId, setEditingId] = useState<string | null>(null)
  const [form, setForm] = useState({ title: '', description: '', location: '', time: '', date: '', dateEnd: '', capacity: 50, category: '', templateImage: '', signatureImage: '', nameColor: '#0066CC' })
  const fileInputRef = useRef<HTMLInputElement>(null)
  const signatureInputRef = useRef<HTMLInputElement>(null)

  const handleTemplateUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]
    if (file) {
      const reader = new FileReader()
      reader.onload = (event) => {
        setForm({ ...form, templateImage: event.target?.result as string })
      }
      reader.readAsDataURL(file)
    }
  }

  const handleSignatureUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]
    if (file) {
      const reader = new FileReader()
      reader.onload = (event) => {
        setForm({ ...form, signatureImage: event.target?.result as string })
      }
      reader.readAsDataURL(file)
    }
  }

  const handleSave = () => {
    if (!form.title || !form.location || !form.date || !form.dateEnd || !form.time) {
      onShowToast('Preencha todos os campos obrigatórios', 'error')
      return
    }

    if (editingId) {
      const updatedEvents = events.map(e => 
        e.id === editingId 
          ? { ...e, title: form.title, description: form.description, location: form.location, time: form.time, date: form.date, dateEnd: form.dateEnd, capacity: form.capacity, category: form.category, templateImage: form.templateImage, signatureImage: form.signatureImage, nameColor: form.nameColor }
          : e
      )
      setEvents(updatedEvents)
      StorageDB.events.set(updatedEvents)
      onShowToast('Evento atualizado!', 'success')
    } else {
      const newEvent: Event = {
        id: 'evt-' + Date.now(),
        title: form.title,
        description: form.description,
        location: form.location,
        time: form.time,
        date: form.date,
        dateEnd: form.dateEnd,
        capacity: form.capacity,
        enrolled: 0,
        category: form.category,
        templateImage: form.templateImage,
        signatureImage: form.signatureImage,
        nameColor: form.nameColor,
      }
      const updatedEvents = [...events, newEvent]
      setEvents(updatedEvents)
      StorageDB.events.set(updatedEvents)
      onShowToast('Evento criado!', 'success')
    }

    setShowModal(false)
    setEditingId(null)
    setForm({ title: '', description: '', location: '', time: '', date: '', dateEnd: '', capacity: 50, category: '', templateImage: '', signatureImage: '', nameColor: '#0066CC' })
  }

  const handleDelete = (id: string) => {
    if (confirm('Tem certeza que deseja deletar este evento?')) {
      const updatedEvents = events.filter(e => e.id !== id)
      setEvents(updatedEvents)
      StorageDB.events.set(updatedEvents)
      onShowToast('Evento deletado!', 'success')
    }
  }

  return (
    <div className="admin-layout">
      <aside className="admin-sidebar">
        <div className="admin-header">
          <img src={logo} alt="QuadCode" className="admin-logo" />
          <h2>Admin</h2>
        </div>
        <nav className="admin-nav">
          <button className="admin-nav-item" onClick={onBack}>
            <span></span> Dashboard
          </button>
          <button className="admin-nav-item active" onClick={() => {}}>
            <span></span> Eventos
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Presença
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Certificados
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Relatórios
          </button>
        </nav>
      </aside>

      <main className="admin-main">
        <header className="admin-header-top">
          <h1>Gerenciar Eventos</h1>
          <button className="btn btn-primary" onClick={() => { setShowModal(true); setEditingId(null); setForm({ title: '', description: '', location: '', time: '', date: '', dateEnd: '', capacity: 50, category: '', templateImage: '', signatureImage: '', nameColor: '#0066CC' }) }}>
             Novo Evento
          </button>
        </header>

        <div className="events-table">
          <table>
            <thead>
              <tr>
                <th>Evento</th>
                <th>Data</th>
                <th>Local</th>
                <th>Inscritos</th>
                <th>Ações</th>
              </tr>
            </thead>
            <tbody>
              {events.map(event => (
                <tr key={event.id}>
                  <td><strong>{event.title}</strong></td>
                  <td>{event.date}</td>
                  <td>{event.location}</td>
                  <td>{event.enrolled}/{event.capacity}</td>
                  <td>
                    <button className="btn btn-sm btn-outline" onClick={() => { setEditingId(event.id); setForm(event); setShowModal(true) }}>Editar</button>
                    <button className="btn btn-sm btn-danger" onClick={() => handleDelete(event.id)}>Deletar</button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        {showModal && (
          <div className="modal-overlay" onClick={() => setShowModal(false)}>
            <div className="modal" onClick={(e) => e.stopPropagation()}>
              <h2>{editingId ? 'Editar Evento' : 'Novo Evento'}</h2>
              <div className="modal-form">
                <div className="form-group">
                  <label>Título *</label>
                  <input type="text" value={form.title} onChange={(e) => setForm({ ...form, title: e.target.value })} className="input" />
                </div>
                <div className="form-group">
                  <label>Descrição</label>
                  <textarea value={form.description} onChange={(e) => setForm({ ...form, description: e.target.value })} className="input" rows={3}></textarea>
                </div>
                <div className="form-row">
                  <div className="form-group">
                    <label>Local *</label>
                    <input type="text" value={form.location} onChange={(e) => setForm({ ...form, location: e.target.value })} className="input" />
                  </div>
                  <div className="form-group">
                    <label>Categoria</label>
                    <input type="text" value={form.category} onChange={(e) => setForm({ ...form, category: e.target.value })} className="input" placeholder="Workshop, Palestra, etc" />
                  </div>
                </div>
                <div className="form-row">
                  <div className="form-group">
                    <label>Data Início *</label>
                    <input type="date" value={form.date} onChange={(e) => setForm({ ...form, date: e.target.value })} className="input" />
                  </div>
                  <div className="form-group">
                    <label>Data Fim *</label>
                    <input type="date" value={form.dateEnd} onChange={(e) => setForm({ ...form, dateEnd: e.target.value })} className="input" />
                  </div>
                  <div className="form-group">
                    <label>Horário *</label>
                    <input type="time" value={form.time} onChange={(e) => setForm({ ...form, time: e.target.value })} className="input" />
                  </div>
                </div>
                <div className="form-group">
                  <label>Capacidade</label>
                  <input type="number" value={form.capacity} onChange={(e) => setForm({ ...form, capacity: parseInt(e.target.value) })} className="input" />
                </div>
                <div className="form-group">
                  <label>Modelo de Certificado</label>
                  <button className="btn btn-outline btn-sm" onClick={() => fileInputRef.current?.click()}>
                    Selecionar Imagem
                  </button>
                  <input ref={fileInputRef} type="file" accept="image/*" onChange={handleTemplateUpload} style={{ display: 'none' }} />
                  {form.templateImage && (
                    <div style={{ marginTop: '12px' }}>
                      <img src={form.templateImage} alt="Template" style={{ maxWidth: '100%', maxHeight: '150px', borderRadius: '8px' }} />
                    </div>
                  )}
                </div>
                <div className="form-group">
                  <label>Assinatura do Responsável</label>
                  <button className="btn btn-outline btn-sm" onClick={() => signatureInputRef.current?.click()}>
                    Selecionar Assinatura
                  </button>
                  <input ref={signatureInputRef} type="file" accept="image/png" onChange={handleSignatureUpload} style={{ display: 'none' }} />
                  {form.signatureImage && (
                    <div style={{ marginTop: '12px' }}>
                      <img src={form.signatureImage} alt="Assinatura" style={{ maxWidth: '100%', maxHeight: '80px', borderRadius: '8px' }} />
                    </div>
                  )}
                </div>
                <div className="form-group">
                  <label>Cor do Nome no Certificado</label>
                  <div style={{ display: 'flex', gap: '12px', alignItems: 'center' }}>
                    <input type="color" value={form.nameColor || '#0066CC'} onChange={(e) => setForm({ ...form, nameColor: e.target.value })} style={{ width: '60px', height: '40px', border: 'none', borderRadius: '8px', cursor: 'pointer' }} />
                    <input type="text" value={form.nameColor || '#0066CC'} onChange={(e) => setForm({ ...form, nameColor: e.target.value })} placeholder="#0066CC" className="input" style={{ flex: 1 }} />
                  </div>
                </div>
                <div className="modal-buttons">
                  <button className="btn btn-primary" onClick={handleSave}>Salvar</button>
                  <button className="btn btn-outline" onClick={() => setShowModal(false)}>Cancelar</button>
                </div>
              </div>
            </div>
          </div>
        )}
      </main>
    </div>
  )
}

// ADMIN QR
function AdminQRScreen({ onBack, onShowToast }: { onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const [qrInput, setQrInput] = useState('')
  const [attendances, setAttendances] = useState<{ qr: string; time: string; event: string; user: string }[]>([])
  const enrollments = StorageDB.enrollments.get()
  const events = StorageDB.events.get()
  const users = StorageDB.users.get()

  const handleQRRead = () => {
    if (!qrInput) {
      onShowToast('Digite ou escaneie um QR Code', 'error')
      return
    }

    const enrollment = enrollments.find(e => e.qrCode === qrInput)
    if (!enrollment) {
      onShowToast('QR Code inválido ou não encontrado', 'error')
      return
    }

    if (enrollment.used) {
      onShowToast('Este QR Code já foi utilizado', 'error')
      return
    }

    const event = events.find(e => e.id === enrollment.eventId)
    const user = users.find(u => u.id === enrollment.userId)
    
    const updatedEnrollments = enrollments.map(e => 
      e.id === enrollment.id ? { ...e, used: true } : e
    )
    StorageDB.enrollments.set(updatedEnrollments)

    const attendancesList = StorageDB.attendances.get()
    attendancesList.push({
      id: 'att-' + Date.now(),
      userId: enrollment.userId,
      eventId: enrollment.eventId,
      attendanceDate: new Date().toISOString(),
    })
    StorageDB.attendances.set(attendancesList)

    setAttendances([...attendances, { 
      qr: qrInput, 
      time: new Date().toLocaleTimeString(), 
      event: event?.title || 'Evento desconhecido',
      user: user?.name || 'Usuário desconhecido'
    }])
    setQrInput('')
    onShowToast('Presença registrada com sucesso!', 'success')
  }

  return (
    <div className="admin-layout">
      <aside className="admin-sidebar">
        <div className="admin-header">
          <img src={logo} alt="QuadCode" className="admin-logo" />
          <h2>Admin</h2>
        </div>
        <nav className="admin-nav">
          <button className="admin-nav-item" onClick={onBack}>
            <span></span> Dashboard
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Eventos
          </button>
          <button className="admin-nav-item active" onClick={() => {}}>
            <span></span> Presença
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Certificados
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Relatórios
          </button>
        </nav>
      </aside>

      <main className="admin-main">
        <header className="admin-header-top">
          <h1>Registrar Presença</h1>
          <p>Escaneie ou digite o QR Code para registrar presença</p>
        </header>

        <div className="qr-section">
          <div className="form-group">
            <label>Digite o código QR ou número</label>
            <input 
              type="text" 
              placeholder="Cole o QR Code ou digite o número" 
              value={qrInput} 
              onChange={(e) => setQrInput(e.target.value)}
              onKeyPress={(e) => e.key === 'Enter' && handleQRRead()}
              className="input"
            />
          </div>
          <button className="btn btn-primary" onClick={handleQRRead}>Registrar Presença</button>
        </div>

        <div className="attendances-table">
          <h2>Presenças Registradas</h2>
          <table>
            <thead>
              <tr>
                <th>Participante</th>
                <th>Evento</th>
                <th>Horário</th>
              </tr>
            </thead>
            <tbody>
              {attendances.length === 0 ? (
                <tr><td colSpan={3} style={{ textAlign: 'center', color: '#999' }}>Nenhuma presença registrada</td></tr>
              ) : (
                attendances.map((att, idx) => (
                  <tr key={idx}>
                    <td>{att.user}</td>
                    <td>{att.event}</td>
                    <td>{att.time}</td>
                  </tr>
                ))
              )}
            </tbody>
          </table>
        </div>
      </main>
    </div>
  )
}

// ADMIN CERTIFICATES
function AdminCertificatesScreen({ onBack, onShowToast }: { onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const users = StorageDB.users.get()
  const events = StorageDB.events.get()
  const attendances = StorageDB.attendances.get()
  const [selectedEvent, setSelectedEvent] = useState('')
  const [selectedDate, setSelectedDate] = useState(new Date().toISOString().split('T')[0])

  const getAttendedUsers = () => {
    if (!selectedEvent) return []
    return attendances
      .filter(a => a.eventId === selectedEvent)
      .map(a => users.find(u => u.id === a.userId))
      .filter(Boolean) as User[]
  }

  const generateCertificate = async (user: User) => {
    const event = events.find(e => e.id === selectedEvent)
    if (!event || !event.templateImage) {
      onShowToast('Evento ou template não encontrado', 'error')
      return
    }

    try {
      const img = new Image()
      img.crossOrigin = 'anonymous'
      img.onload = () => {
        const canvas = document.createElement('canvas')
        canvas.width = 1200
        canvas.height = 800
        const ctx = canvas.getContext('2d')
        if (!ctx) return

        ctx.drawImage(img, 0, 0, 1200, 800)
        ctx.font = 'italic 70px Georgia'
        ctx.fillStyle = event.nameColor || '#0066CC'
        ctx.textAlign = 'center'
        ctx.fillText(user.name, 600, 320)

        if (event.signatureImage) {
          const sig = new Image()
          sig.crossOrigin = 'anonymous'
          sig.onload = () => {
            ctx.drawImage(sig, 900, 650, 200, 80)
            finalizeCertificate(canvas.toDataURL('image/png'))
          }
          sig.onerror = () => finalizeCertificate(canvas.toDataURL('image/png'))
          sig.src = event.signatureImage
        } else {
          finalizeCertificate(canvas.toDataURL('image/png'))
        }
      }
      img.onerror = () => {
        onShowToast('Erro ao carregar template', 'error')
      }
      img.src = event.templateImage

      const finalizeCertificate = (certificateImage: string) => {
        const certificates = StorageDB.certificates.get()
        certificates.push({
          id: 'cert-' + Date.now() + Math.random(),
          userId: user.id,
          userName: user.name,
          eventId: selectedEvent,
          eventTitle: event.title,
          issueDate: selectedDate,
          status: 'sent',
          certificateImage,
        })
        StorageDB.certificates.set(certificates)
        onShowToast(`Certificado gerado para ${user.name}!`, 'success')
      }
    } catch (err) {
      onShowToast('Erro ao gerar certificado', 'error')
    }
  }

  const attendedUsers = getAttendedUsers()

  return (
    <div className="admin-layout">
      <aside className="admin-sidebar">
        <div className="admin-header">
          <img src={logo} alt="QuadCode" className="admin-logo" />
          <h2>Admin</h2>
        </div>
        <nav className="admin-nav">
          <button className="admin-nav-item" onClick={onBack}>
            <span></span> Dashboard
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Eventos
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Presença
          </button>
          <button className="admin-nav-item active" onClick={() => {}}>
            <span></span> Certificados
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Relatórios
          </button>
        </nav>
      </aside>

      <main className="admin-main">
        <header className="admin-header-top">
          <h1>Gerar Certificados</h1>
          <p>Selecione um evento e gere certificados para os participantes</p>
        </header>

        <div className="certificate-generator">
          <div className="form-row">
            <div className="form-group">
              <label>Selecione o Evento *</label>
              <select value={selectedEvent} onChange={(e) => setSelectedEvent(e.target.value)} className="input">
                <option value="">-- Escolha um evento --</option>
                {events.map(event => (
                  <option key={event.id} value={event.id}>{event.title}</option>
                ))}
              </select>
            </div>
            <div className="form-group">
              <label>Data de Emissão</label>
              <input type="date" value={selectedDate} onChange={(e) => setSelectedDate(e.target.value)} className="input" />
            </div>
          </div>
        </div>

        {selectedEvent && (
          <div className="certificates-list">
            <h2>Participantes com Presença Confirmada</h2>
            <table>
              <thead>
                <tr>
                  <th>Nome</th>
                  <th>Email</th>
                  <th>Ação</th>
                </tr>
              </thead>
              <tbody>
                {attendedUsers.length === 0 ? (
                  <tr><td colSpan={3} style={{ textAlign: 'center', color: '#999' }}>Nenhum participante com presença confirmada</td></tr>
                ) : (
                  attendedUsers.map(user => (
                    <tr key={user.id}>
                      <td>{user.name}</td>
                      <td>{user.email}</td>
                      <td>
                        <button className="btn btn-primary btn-sm" onClick={() => generateCertificate(user)}>
                          Gerar
                        </button>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        )}
      </main>
    </div>
  )
}

// ADMIN REPORTS
function AdminReportsScreen({ onBack }: { onBack: () => void }) {
  const events = StorageDB.events.get()
  const users = StorageDB.users.get()
  const enrollments = StorageDB.enrollments.get()
  const attendances = StorageDB.attendances.get()
  const certificates = StorageDB.certificates.get()

  return (
    <div className="admin-layout">
      <aside className="admin-sidebar">
        <div className="admin-header">
          <img src={logo} alt="QuadCode" className="admin-logo" />
          <h2>Admin</h2>
        </div>
        <nav className="admin-nav">
          <button className="admin-nav-item" onClick={onBack}>
            <span></span> Dashboard
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Eventos
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Presença
          </button>
          <button className="admin-nav-item" onClick={() => {}}>
            <span></span> Certificados
          </button>
          <button className="admin-nav-item active" onClick={() => {}}>
            <span></span> Relatórios
          </button>
        </nav>
      </aside>

      <main className="admin-main">
        <header className="admin-header-top">
          <h1>Relatórios</h1>
          <p>Visualize estatísticas e métricas do sistema</p>
        </header>

        <div className="reports-grid">
          <div className="report-card">
            <h3>Resumo Geral</h3>
            <div className="report-item">
              <span>Total de Eventos:</span>
              <strong>{events.length}</strong>
            </div>
            <div className="report-item">
              <span>Total de Usuários:</span>
              <strong>{users.length}</strong>
            </div>
            <div className="report-item">
              <span>Total de Inscrições:</span>
              <strong>{enrollments.length}</strong>
            </div>
            <div className="report-item">
              <span>Total de Presenças:</span>
              <strong>{attendances.length}</strong>
            </div>
            <div className="report-item">
              <span>Total de Certificados:</span>
              <strong>{certificates.length}</strong>
            </div>
          </div>

          <div className="report-card">
            <h3>Taxa de Participação</h3>
            {events.map(event => (
              <div key={event.id} className="report-item">
                <span>{event.title}:</span>
                <strong>{event.enrolled}/{event.capacity} ({Math.round((event.enrolled / event.capacity) * 100)}%)</strong>
              </div>
            ))}
          </div>

          <div className="report-card">
            <h3>Taxa de Presença</h3>
            {events.map(event => {
              const eventEnrollments = enrollments.filter(e => e.eventId === event.id)
              const eventAttendances = attendances.filter(a => a.eventId === event.id)
              const rate = eventEnrollments.length > 0 ? Math.round((eventAttendances.length / eventEnrollments.length) * 100) : 0
              return (
                <div key={event.id} className="report-item">
                  <span>{event.title}:</span>
                  <strong>{eventAttendances.length}/{eventEnrollments.length} ({rate}%)</strong>
                </div>
              )
            })}
          </div>

          <div className="report-card">
            <h3>Certificados Emitidos</h3>
            {events.map(event => {
              const eventCerts = certificates.filter(c => c.eventId === event.id)
              return (
                <div key={event.id} className="report-item">
                  <span>{event.title}:</span>
                  <strong>{eventCerts.length}</strong>
                </div>
              )
            })}
          </div>
        </div>
      </main>
    </div>
  )
}

// MAIN APP
export default function App() {
  const [screen, setScreen] = useState<Screen>('landing')
  const [user, setUser] = useState<User | null>(null)
  const [isAdmin, setIsAdmin] = useState(false)
  const [toasts, setToasts] = useState<Toast[]>([])

  const showToast = (message: string, type: 'success' | 'error' | 'info') => {
    const id = Date.now().toString()
    setToasts(prev => [...prev, { id, message, type }])
  }

  const removeToast = (id: string) => {
    setToasts(prev => prev.filter(t => t.id !== id))
  }

  useEffect(() => {
    const handler = (event: Event) => {
      const custom = event as CustomEvent<Screen>
      setScreen(custom.detail)
    }
    window.addEventListener('navigate-screen', handler as EventListener)
    return () => window.removeEventListener('navigate-screen', handler as EventListener)
  }, [])

  return (
    <div className="app">
      {screen === 'landing' && <LandingPage onLogin={() => setScreen('login')} onRegister={() => setScreen('register')} onAdmin={() => setScreen('admin-login')} />}
      {screen === 'login' && <LoginScreen onBack={() => setScreen('landing')} onLogin={(u) => { setUser(u); setScreen('home') }} />}
      {screen === 'register' && <RegisterScreen onBack={() => setScreen('landing')} onRegister={(u) => { setUser(u); setScreen('home') }} onShowToast={showToast} />}
      {screen === 'home' && user && <HomeScreen user={user} onLogout={() => { setUser(null); setScreen('landing') }} onNavigate={setScreen} />}
      {screen === 'events' && user && <EventsScreen user={user} onBack={() => setScreen('home')} onShowToast={showToast} />}
      {screen === 'certificates' && user && <CertificatesScreen user={user} onBack={() => setScreen('home')} onShowToast={showToast} />}
      {screen === 'download-certificates' && user && <DownloadCertificatesScreen user={user} onBack={() => setScreen('home')} onShowToast={showToast} />}
      {screen === 'profile' && user && <ProfileScreen user={user} onBack={() => setScreen('home')} onUpdateUser={setUser} onShowToast={showToast} />}
      {screen === 'admin-login' && <AdminLoginScreen onBack={() => setScreen('landing')} onLogin={() => { setIsAdmin(true); setScreen('admin-home') }} />}
      {screen === 'admin-home' && isAdmin && <AdminHomeScreen onLogout={() => { setIsAdmin(false); setScreen('landing') }} onNavigate={setScreen} />}
      {screen === 'admin-events' && isAdmin && <AdminEventsScreen onBack={() => setScreen('admin-home')} onShowToast={showToast} />}
      {screen === 'admin-qr' && isAdmin && <AdminQRScreen onBack={() => setScreen('admin-home')} onShowToast={showToast} />}
      {screen === 'admin-certificates' && isAdmin && <AdminCertificatesScreen onBack={() => setScreen('admin-home')} onShowToast={showToast} />}
      {screen === 'admin-reports' && isAdmin && <AdminReportsScreen onBack={() => setScreen('admin-home')} />}

      {/* Toasts */}
      <div className="toasts-container">
        {toasts.map(toast => (
          <Toast key={toast.id} toast={toast} onClose={() => removeToast(toast.id)} />
        ))}
      </div>
    </div>
  )
}
