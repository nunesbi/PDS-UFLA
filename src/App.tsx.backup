// LOGIN
function LoginScreen({ onBack, onLogin }: { onBack: () => void; onLogin: (user: User) => void }) {
  const [email, setEmail] = useState('')
  const [password, setPassword] = useState('')
  const [error, setError] = useState('')

  const handleLogin = () => {
    setError('')
    if (!email || !password) {
      setError('Preencha email e senha')
      return
    }

    const user = StorageDB.users.get().find(u => u.email === email)
    if (!user) {
      setError('Usuário não encontrado')
      return
    }

    if (user.password !== password) {
      setError('Senha incorreta')
      return
    }

    onLogin(user)
  }

  return (
    <div className="auth-page">
      <div className="auth-container">
        <button className="back-btn" onClick={onBack}> Voltar</button>
        <div className="auth-header">
          <img src={logo} alt="QuadCode" className="auth-logo" />
          <h2>Login</h2>
        </div>
        
        {error && <div className="error-message">{error}</div>}
        
        <div className="form-group">
          <label>Email</label>
          <input type="email" placeholder="seu@email.com" value={email} onChange={(e) => setEmail(e.target.value)} className="input" />
        </div>
        <div className="form-group">
          <label>Senha</label>
          <input type="password" placeholder="••••••••" value={password} onChange={(e) => setPassword(e.target.value)} className="input" />
        </div>
        <button className="btn btn-primary" onClick={handleLogin} style={{ width: '100%' }}>Entrar</button>
        
        <div style={{ margin: '24px 0', display: 'flex', alignItems: 'center', gap: '12px' }}>
          <div style={{ flex: 1, height: '1px', background: '#E5E7EB' }}></div>
          <span style={{ color: '#999', fontSize: '14px' }}>ou</span>
          <div style={{ flex: 1, height: '1px', background: '#E5E7EB' }}></div>
        </div>

        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '12px' }}>
          <button className="btn btn-outline" onClick={() => {
            const user: User = {
              id: 'user-' + Date.now(),
              name: 'Usuário Google',
              email: 'google@example.com',
              cpf: '000.000.000-00',
              institution: 'UFLA',
              password: 'oauth-google',
              enrolledEvents: [],
            }
            onLogin(user)
          }} style={{ fontSize: '20px' }}>G</button>
          <button className="btn btn-outline" onClick={() => {
            const user: User = {
              id: 'user-' + Date.now(),
              name: 'Usuário Microsoft',
              email: 'microsoft@example.com',
              cpf: '000.000.000-00',
              institution: 'UFLA',
              password: 'oauth-microsoft',
              enrolledEvents: [],
            }
            onLogin(user)
          }} style={{ fontSize: '20px' }}>MS</button>
          <button className="btn btn-outline" onClick={() => {
            const user: User = {
              id: 'user-' + Date.now(),
              name: 'Usuário Apple',
              email: 'apple@example.com',
              cpf: '000.000.000-00',
              institution: 'UFLA',
              password: 'oauth-apple',
              enrolledEvents: [],
            }
            onLogin(user)
          }} style={{ fontSize: '20px' }}>A</button>
        </div>

        <p style={{ marginTop: '20px', textAlign: 'center', fontSize: '12px', color: '#666' }}>
          Não tem conta? <button onClick={onBack} style={{ color: '#0066CC', textDecoration: 'underline', background: 'none', border: 'none', cursor: 'pointer' }}>Registre-se</button>
        </p>
      </div>
    </div>
  )
}

// REGISTER
function RegisterScreen({ onBack, onRegister, onShowToast }: { onBack: () => void; onRegister: (user: User) => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const [form, setForm] = useState({ name: '', email: '', cpf: '', institution: '', password: '', confirmPassword: '' })
  const [error, setError] = useState('')
  const [passwordErrors, setPasswordErrors] = useState<string[]>([])

  const handlePasswordChange = (pwd: string) => {
    setForm({ ...form, password: pwd })
    const validation = validatePassword(pwd)
    setPasswordErrors(validation.errors)
  }

  const handleRegister = () => {
    setError('')

    if (!form.name || !form.email || !form.cpf || !form.institution || !form.password) {
      setError('Preencha todos os campos')
      return
    }

    const validation = validatePassword(form.password)
    if (!validation.valid) {
      setError('Senha não atende aos requisitos')
      return
    }

    if (form.password !== form.confirmPassword) {
      setError('Senhas não conferem')
      return
    }

    const userExists = StorageDB.users.get().find(u => u.email === form.email)
    if (userExists) {
      setError('Email já cadastrado')
      return
    }

    const newUser: User = {
      id: 'user-' + Date.now(),
      name: form.name,
      email: form.email,
      cpf: form.cpf,
      institution: form.institution,
      password: form.password,
      enrolledEvents: [],
    }

    const users = StorageDB.users.get()
    users.push(newUser)
    StorageDB.users.set(users)

    onShowToast('Conta criada com sucesso!', 'success')
    onRegister(newUser)
  }

  return (
    <div className="auth-page">
      <div className="auth-container">
        <button className="back-btn" onClick={onBack}> Voltar</button>
        <div className="auth-header">
          <img src={logo} alt="QuadCode" className="auth-logo" />
          <h2>Criar Conta</h2>
        </div>
        
        {error && <div className="error-message">{error}</div>}
        
        <div className="form-group">
          <label>Nome Completo</label>
          <input type="text" placeholder="João Silva" value={form.name} onChange={(e) => setForm({ ...form, name: e.target.value })} className="input" />
        </div>
        <div className="form-group">
          <label>Email</label>
          <input type="email" placeholder="seu@email.com" value={form.email} onChange={(e) => setForm({ ...form, email: e.target.value })} className="input" />
        </div>
        <div className="form-group">
          <label>CPF</label>
          <input type="text" placeholder="000.000.000-00" value={form.cpf} onChange={(e) => setForm({ ...form, cpf: e.target.value })} className="input" />
        </div>
        <div className="form-group">
          <label>Instituição</label>
          <input type="text" placeholder="UFLA" value={form.institution} onChange={(e) => setForm({ ...form, institution: e.target.value })} className="input" />
        </div>
        <div className="form-group">
          <label>Senha</label>
          <input type="password" placeholder="••••••••" value={form.password} onChange={(e) => handlePasswordChange(e.target.value)} className="input" />
          {passwordErrors.length > 0 && (
            <div className="password-requirements">
              {passwordErrors.map((err, i) => (
                <div key={i} className="requirement-error"> {err}</div>
              ))}
            </div>
          )}
          {form.password && passwordErrors.length === 0 && (
            <div className="password-requirements">
              <div className="requirement-success"> Senha forte</div>
            </div>
          )}
        </div>
        <div className="form-group">
          <label>Confirmar Senha</label>
          <input type="password" placeholder="••••••••" value={form.confirmPassword} onChange={(e) => setForm({ ...form, confirmPassword: e.target.value })} className="input" />
        </div>
        <button className="btn btn-primary" onClick={handleRegister} style={{ width: '100%' }}>Criar Conta</button>
      </div>
    </div>
  )
}

