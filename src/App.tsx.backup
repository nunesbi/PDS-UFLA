// EVENTS SCREEN
function EventsScreen({ user, onBack, onShowToast }: { user: User; onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const [events, setEvents] = useState(StorageDB.events.get())

  const handleEnroll = async (event: Event) => {
    if (user.enrolledEvents.includes(event.id)) {
      onShowToast('Você já está inscrito neste evento', 'info')
      return
    }
    const qrData = `CUFLA-${user.id}-${event.id}-${Math.random().toString(36).substr(2, 9).toUpperCase()}`
    const qrCodeImage = await QRCode.toDataURL(qrData)
    const enrollments = StorageDB.enrollments.get()
    enrollments.push({ id: 'enr-' + Date.now(), userId: user.id, eventId: event.id, qrCode: qrData, qrCodeImage, enrollmentDate: new Date().toISOString(), used: false })
    StorageDB.enrollments.set(enrollments)
    user.enrolledEvents.push(event.id)
    const users = StorageDB.users.get()
    const userIndex = users.findIndex(u => u.id === user.id)
    if (userIndex !== -1) {
      users[userIndex] = user
      StorageDB.users.set(users)
    }
    event.enrolled++
    const updatedEvents = events.map(e => e.id === event.id ? event : e)
    setEvents(updatedEvents)
    StorageDB.events.set(updatedEvents)
    onShowToast('Inscrição realizada com sucesso! QR Code gerado.', 'success')
  }

  return (
    <div className="dashboard-layout">
      <aside className="sidebar">
        <div className="sidebar-header">
          <img src={logo} alt="QuadCode" className="sidebar-logo" />
        </div>
        <nav className="sidebar-nav">
          <button className="nav-item" onClick={onBack}>
            <span className="nav-icon"></span>
            <span>Início</span>
          </button>
          <button className="nav-item active" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Programação</span>
          </button>
          <button className="nav-item" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Inscrições</span>
          </button>
          <button className="nav-item" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Certificados</span>
          </button>
          <button className="nav-item" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Perfil</span>
          </button>
        </nav>
      </aside>

      <main className="main-content">
        <header className="dashboard-header">
          <h1>Programação do Evento</h1>
          <p>Confira todos os eventos disponíveis e faça sua inscrição</p>
        </header>

        <div className="events-list">
          {events.map(event => (
            <div key={event.id} className="event-list-item">
              <div className="event-time">
                <strong>{event.time}</strong>
                <span>{event.date}</span>
              </div>
              <div className="event-details">
                <h3>{event.title}</h3>
                <p>{event.description}</p>
                <div className="event-meta">
                  <span> {event.location}</span>
                  <span> {event.enrolled}/{event.capacity}</span>
                </div>
              </div>
              <button 
                className={`btn ${user.enrolledEvents.includes(event.id) ? 'btn-outline' : 'btn-primary'} btn-sm`}
                onClick={() => handleEnroll(event)}
                disabled={user.enrolledEvents.includes(event.id)}
              >
                {user.enrolledEvents.includes(event.id) ? 'Inscrito' : 'Inscrever'}
              </button>
            </div>
          ))}
        </div>
      </main>
    </div>
  )
}

// CERTIFICATES SCREEN
function CertificatesScreen({ user, onBack, onShowToast }: { user: User; onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const enrollments = StorageDB.enrollments.get().filter(e => e.userId === user.id)
  const events = StorageDB.events.get()
  const unusedEnrollments = enrollments.filter(e => !e.used)

  const downloadQRCode = (enrollment: Enrollment) => {
    const link = document.createElement('a')
    link.href = enrollment.qrCodeImage
    link.download = `qrcode-${enrollment.id}.png`
    link.click()
    onShowToast('QR Code baixado!', 'success')
  }

  return (
    <div className="dashboard-layout">
      <aside className="sidebar">
        <div className="sidebar-header">
          <img src={logo} alt="QuadCode" className="sidebar-logo" />
        </div>
        <nav className="sidebar-nav">
          <button className="nav-item" onClick={onBack}>
            <span className="nav-icon"></span>
            <span>Início</span>
          </button>
          <button className="nav-item active" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Inscrições</span>
          </button>
        </nav>
      </aside>

      <main className="main-content">
        <header className="dashboard-header">
          <h1>Meus QR Codes</h1>
          <p>Guarde seus QR Codes para confirmar presença</p>
        </header>

        {unusedEnrollments.length === 0 ? (
          <div className="empty-state">
            <p>Você ainda não possui QR Codes disponíveis.</p>
            <p>Faça sua inscrição na programação para gerar o QR Code.</p>
          </div>
        ) : (
          <div className="qr-list">
            {unusedEnrollments.map(enrollment => {
              const event = events.find(e => e.id === enrollment.eventId)
              return (
                <div key={enrollment.id} className="qr-card">
                  <div className="qr-content">
                    <h3>{event?.title}</h3>
                    <p>{event?.location} • {event?.date}</p>
                  </div>
                  <div className="qr-preview">
                    <img src={enrollment.qrCodeImage} alt="QR Code" />
                  </div>
                  <div className="qr-code-text" style={{ fontSize: "12px", fontWeight: "bold", color: "#666", marginTop: "8px", letterSpacing: "1px" }}>{enrollment.qrCode}</div>
                  <button className="btn btn-primary btn-sm" onClick={() => downloadQRCode(enrollment)}>Baixar QR</button>
                </div>
              )
            })}
          </div>
        )}
      </main>
    </div>
  )
}

// DOWNLOAD CERTIFICATES SCREEN
function DownloadCertificatesScreen({ user, onBack, onShowToast }: { user: User; onBack: () => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const certificates = StorageDB.certificates.get().filter(c => c.userId === user.id)

  const downloadCertificate = async (cert: Certificate) => {
    if (cert.certificateImage) {
      const link = document.createElement('a')
      link.href = cert.certificateImage
      link.download = `certificado-${cert.id}.png`
      link.click()
      onShowToast('Certificado baixado!', 'success')
    } else {
      onShowToast('Certificado não disponível', 'error')
    }
  }

  return (
    <div className="dashboard-layout">
      <aside className="sidebar">
        <div className="sidebar-header">
          <img src={logo} alt="QuadCode" className="sidebar-logo" />
        </div>
        <nav className="sidebar-nav">
          <button className="nav-item" onClick={onBack}>
            <span className="nav-icon"></span>
            <span>Início</span>
          </button>
          <button className="nav-item active" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Certificados</span>
          </button>
        </nav>
      </aside>

      <main className="main-content">
        <header className="dashboard-header">
          <h1>Meus Certificados</h1>
          <p>Consulte e baixe seus certificados emitidos</p>
        </header>

        {certificates.length === 0 ? (
          <div className="empty-state">
            <p>Você ainda não possui certificados.</p>
            <p>Confirme presença nos eventos para habilitar a emissão.</p>
          </div>
        ) : (
          <div className="certificates-list">
            {certificates.map(cert => (
              <div key={cert.id} className="certificate-card">
                <div className="cert-content">
                  <h3>{cert.eventTitle}</h3>
                  <p>Emissão: {cert.issueDate}</p>
                  <span className={`badge badge-${cert.status}`}>{cert.status === 'sent' ? 'Enviado' : 'Pendente'}</span>
                </div>
                <button className="btn btn-primary btn-sm" onClick={() => downloadCertificate(cert)}>Baixar</button>
              </div>
            ))}
          </div>
        )}
      </main>
    </div>
  )
}

// PROFILE SCREEN
function ProfileScreen({ user, onBack, onUpdateUser, onShowToast }: { user: User; onBack: () => void; onUpdateUser: (user: User) => void; onShowToast: (msg: string, type: 'success' | 'error' | 'info') => void }) {
  const [form, setForm] = useState(user)

  const handleSave = () => {
    const users = StorageDB.users.get()
    const userIndex = users.findIndex(u => u.id === user.id)
    if (userIndex !== -1) {
      users[userIndex] = form
      StorageDB.users.set(users)
      onUpdateUser(form)
      onShowToast('Perfil atualizado com sucesso!', 'success')
      onBack()
    }
  }

  return (
    <div className="dashboard-layout">
      <aside className="sidebar">
        <div className="sidebar-header">
          <img src={logo} alt="QuadCode" className="sidebar-logo" />
        </div>
        <nav className="sidebar-nav">
          <button className="nav-item" onClick={onBack}>
            <span className="nav-icon"></span>
            <span>Início</span>
          </button>
          <button className="nav-item active" onClick={() => {}}>
            <span className="nav-icon"></span>
            <span>Perfil</span>
          </button>
        </nav>
      </aside>

      <main className="main-content">
        <header className="dashboard-header">
          <h1>Meu Perfil</h1>
          <p>Atualize suas informações pessoais</p>
        </header>

        <div className="profile-form">
          <div className="form-group">
            <label>Nome</label>
            <input type="text" value={form.name} onChange={(e) => setForm({ ...form, name: e.target.value })} className="input" />
          </div>
          <div className="form-group">
            <label>Email</label>
            <input type="email" value={form.email} onChange={(e) => setForm({ ...form, email: e.target.value })} className="input" />
          </div>
          <div className="form-group">
            <label>CPF</label>
            <input type="text" value={form.cpf} onChange={(e) => setForm({ ...form, cpf: e.target.value })} className="input" />
          </div>
          <div className="form-group">
            <label>Instituição</label>
            <input type="text" value={form.institution} onChange={(e) => setForm({ ...form, institution: e.target.value })} className="input" />
          </div>
          <div className="form-actions">
            <button className="btn btn-primary" onClick={handleSave}>Salvar Alterações</button>
            <button className="btn btn-outline" onClick={onBack}>Cancelar</button>
          </div>
        </div>
      </main>
    </div>
  )
}

// ADMIN LOGIN
function AdminLoginScreen({ onBack, onLogin }: { onBack: () => void; onLogin: () => void }) {
  const [email, setEmail] = useState('')
  const [password, setPassword] = useState('')
  const [error, setError] = useState('')

  const handleLogin = () => {
    setError('')
    if (email === 'admin@ufla.br' && password === 'Admin123!') {
      onLogin()
    } else {
      setError('Credenciais inválidas')
    }
  }

  return (
    <div className="auth-page">
      <div className="auth-container">
        <button className="back-btn" onClick={onBack}> Voltar</button>
        <div className="auth-header">
          <img src={logo} alt="QuadCode" className="auth-logo" />
          <h2>Painel Administrativo</h2>
        </div>
        
        {error && <div className="error-message">{error}</div>}
        
        <div className="form-group">
          <label>Email</label>
          <input type="email" placeholder="admin@ufla.br" value={email} onChange={(e) => setEmail(e.target.value)} className="input" />
        </div>
        <div className="form-group">
          <label>Senha</label>
          <input type="password" placeholder="••••••••" value={password} onChange={(e) => setPassword(e.target.value)} className="input" />
        </div>
        <button className="btn btn-primary" onClick={handleLogin} style={{ width: '100%' }}>Entrar</button>
        <p style={{ marginTop: '16px', fontSize: '12px', color: '#666', textAlign: 'center' }}>
          Demo: admin@ufla.br / Admin123!
        </p>
      </div>
    </div>
  )
}

